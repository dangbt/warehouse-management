generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Department {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  description String?
  users       User[]
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("departments")
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  passwordHash   String    @map("password_hash")
  fullName       String    @map("full_name")
  phone          String?
  avatarUrl      String?   @map("avatar_url")
  departmentId   String?   @map("department_id")
  department     Department? @relation(fields: [departmentId], references: [id])
  isActive       Boolean   @default(true) @map("is_active")
  lastLoginAt    DateTime? @map("last_login_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  userRoles      UserRole[]
  auditLogs      AuditLog[]
  importOrders   ImportOrder[] @relation("CreatedBy")
  approvedOrders ImportOrder[] @relation("ApprovedBy")
  stockTransactions StockTransaction[]
  stocktakeSessions  StocktakeSession[] @relation("StocktakeCreatedBy")
  purchaseReturns    PurchaseReturn[] @relation("ReturnCreatedBy")
  supplierPayments   SupplierPayment[] @relation("PaymentCreatedBy")

  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  description String?
  permissions RolePermission[]
  userRoles   UserRole[]

  @@map("roles")
}

model RolePermission {
  id       String @id @default(uuid())
  roleId   String @map("role_id")
  role     Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  resource String
  action   String

  @@unique([roleId, resource, action])
  @@map("role_permissions")
}

model UserRole {
  userId String @map("user_id")
  roleId String @map("role_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model Ingredient {
  id           String   @id @default(uuid())
  name         String   @unique
  unit         String
  minStock     Decimal  @default(0) @map("min_stock") @db.Decimal(10, 3)
  currentStock Decimal  @default(0) @map("current_stock") @db.Decimal(10, 3)
  costPerUnit  Decimal  @default(0) @map("cost_per_unit") @db.Decimal(12, 2)
  category     String
  createdAt    DateTime @default(now()) @map("created_at")
  importOrderItems ImportOrderItem[]
  stockTransactions StockTransaction[]
  recipeIngredients RecipeIngredient[]
  batches      IngredientBatch[]
  stocktakeItems StocktakeItem[]
  purchaseReturnItems PurchaseReturnItem[]

  @@map("ingredients")
}

model Supplier {
  id         String  @id @default(uuid())
  name       String
  phone      String?
  address    String?
  note       String?
  totalDebt  Decimal @default(0) @map("total_debt") @db.Decimal(14, 2)
  importOrders    ImportOrder[]
  purchaseReturns PurchaseReturn[]
  payments        SupplierPayment[]

  @@map("suppliers")
}

model ImportOrder {
  id          String   @id @default(uuid())
  code        String   @unique
  supplierId  String   @map("supplier_id")
  supplier    Supplier @relation(fields: [supplierId], references: [id])
  totalAmount Decimal  @default(0) @map("total_amount") @db.Decimal(14, 2)
  status      String   @default("PENDING")
  note        String?
  createdById String   @map("created_by")
  createdBy   User     @relation("CreatedBy", fields: [createdById], references: [id])
  approvedById String? @map("approved_by")
  approvedBy  User?    @relation("ApprovedBy", fields: [approvedById], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")
  items       ImportOrderItem[]

  @@map("import_orders")
}

model ImportOrderItem {
  id            String   @id @default(uuid())
  importOrderId String   @map("import_order_id")
  importOrder   ImportOrder @relation(fields: [importOrderId], references: [id], onDelete: Cascade)
  ingredientId  String   @map("ingredient_id")
  ingredient    Ingredient @relation(fields: [ingredientId], references: [id])
  quantity      Decimal  @db.Decimal(10, 3)
  unitPrice     Decimal  @map("unit_price") @db.Decimal(12, 2)
  totalPrice    Decimal  @map("total_price") @db.Decimal(14, 2)
  expiryDate    DateTime? @map("expiry_date") @db.Date
  batch         IngredientBatch?

  @@map("import_order_items")
}

model IngredientBatch {
  id                String    @id @default(uuid())
  ingredientId      String    @map("ingredient_id")
  ingredient        Ingredient @relation(fields: [ingredientId], references: [id])
  importOrderItemId String?   @unique @map("import_order_item_id")
  importOrderItem   ImportOrderItem? @relation(fields: [importOrderItemId], references: [id])
  batchCode         String    @map("batch_code")
  quantity          Decimal   @db.Decimal(10, 3)
  costPerUnit       Decimal   @map("cost_per_unit") @db.Decimal(12, 2)
  expiryDate        DateTime? @map("expiry_date") @db.Date
  receivedDate      DateTime  @map("received_date")
  status            String    @default("ACTIVE")
  note              String?
  createdAt         DateTime  @default(now()) @map("created_at")

  @@index([ingredientId, status])
  @@map("ingredient_batches")
}

model StockTransaction {
  id           String   @id @default(uuid())
  ingredientId String   @map("ingredient_id")
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  type         String
  quantity     Decimal  @db.Decimal(10, 3)
  unitPrice    Decimal? @map("unit_price") @db.Decimal(12, 2)
  totalPrice   Decimal? @map("total_price") @db.Decimal(14, 2)
  referenceId  String?  @map("reference_id")
  note         String?
  createdById  String   @map("created_by")
  createdBy    User     @relation(fields: [createdById], references: [id])
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([ingredientId, createdAt])
  @@index([referenceId, type])
  @@map("stock_transactions")
}

model MenuItem {
  id       String  @id @default(uuid())
  name     String
  price    Decimal @db.Decimal(12, 2)
  category String
  isActive Boolean @default(true) @map("is_active")
  recipe   Recipe?
  kiotVietOrderItems KiotVietOrderItem[]

  @@map("menu_items")
}

model Recipe {
  id          String   @id @default(uuid())
  menuItemId  String   @unique @map("menu_item_id")
  menuItem    MenuItem @relation(fields: [menuItemId], references: [id])
  name        String
  servingSize Int      @default(1) @map("serving_size")
  ingredients RecipeIngredient[]

  @@map("recipes")
}

model RecipeIngredient {
  id           String     @id @default(uuid())
  recipeId     String     @map("recipe_id")
  recipe       Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredientId String     @map("ingredient_id")
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  quantity     Decimal    @db.Decimal(10, 3)
  unit         String
  note         String?

  @@map("recipe_ingredients")
}

model KiotVietOrder {
  id            String   @id @default(uuid())
  kiotVietId    String   @unique @map("kiotviet_id")
  code          String
  customerName  String?  @map("customer_name")
  totalAmount   Decimal  @map("total_amount") @db.Decimal(14, 2)
  status        String   @default("SYNCED")
  deducted      Boolean  @default(false)
  orderDate     DateTime @map("order_date")
  syncedAt      DateTime @default(now()) @map("synced_at")
  items         KiotVietOrderItem[]

  @@index([orderDate])
  @@map("kiotviet_orders")
}

model KiotVietOrderItem {
  id          String   @id @default(uuid())
  orderId     String   @map("order_id")
  order       KiotVietOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productName String   @map("product_name")
  menuItemId  String?  @map("menu_item_id")
  menuItem    MenuItem? @relation(fields: [menuItemId], references: [id])
  quantity    Int
  price       Decimal  @db.Decimal(12, 2)

  @@map("kiotviet_order_items")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  user       User?    @relation(fields: [userId], references: [id])
  action     String
  resource   String
  resourceId String?  @map("resource_id")
  oldValues  Json?    @map("old_values")
  newValues  Json?    @map("new_values")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([resource, resourceId])
  @@map("audit_logs")
}



model StocktakeSession {
  id          String    @id @default(uuid())
  code        String    @unique
  status      String    @default("DRAFT")
  note        String?
  createdById String    @map("created_by")
  createdBy   User      @relation("StocktakeCreatedBy", fields: [createdById], references: [id])
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  items       StocktakeItem[]

  @@map("stocktake_sessions")
}

model StocktakeItem {
  id           String           @id @default(uuid())
  sessionId    String           @map("session_id")
  session      StocktakeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  ingredientId String           @map("ingredient_id")
  ingredient   Ingredient       @relation(fields: [ingredientId], references: [id])
  systemQty    Decimal          @map("system_qty") @db.Decimal(10, 3)
  actualQty    Decimal          @map("actual_qty") @db.Decimal(10, 3)
  difference   Decimal          @db.Decimal(10, 3)
  note         String?

  @@map("stocktake_items")
}



model PurchaseReturn {
  id          String   @id @default(uuid())
  code        String   @unique
  supplierId  String   @map("supplier_id")
  supplier    Supplier @relation(fields: [supplierId], references: [id])
  totalAmount Decimal  @default(0) @map("total_amount") @db.Decimal(14, 2)
  reason      String
  note        String?
  createdById String   @map("created_by")
  createdBy   User     @relation("ReturnCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")
  items       PurchaseReturnItem[]

  @@map("purchase_returns")
}

model PurchaseReturnItem {
  id             String         @id @default(uuid())
  returnId       String         @map("return_id")
  purchaseReturn PurchaseReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
  ingredientId   String         @map("ingredient_id")
  ingredient     Ingredient     @relation(fields: [ingredientId], references: [id])
  quantity       Decimal        @db.Decimal(10, 3)
  unitPrice      Decimal        @map("unit_price") @db.Decimal(12, 2)
  totalPrice     Decimal        @map("total_price") @db.Decimal(14, 2)

  @@map("purchase_return_items")
}

model SupplierPayment {
  id          String   @id @default(uuid())
  supplierId  String   @map("supplier_id")
  supplier    Supplier @relation(fields: [supplierId], references: [id])
  amount      Decimal  @db.Decimal(14, 2)
  method      String
  note        String?
  createdById String   @map("created_by")
  createdBy   User     @relation("PaymentCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("supplier_payments")
}
